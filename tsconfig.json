{
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "paths": {
      "@site/*": ["./*"]
    }
  },
  "include": ["src/", "docusaurus.config.ts", "sidebars.servers.ts", "sidebars.skills.ts", "sidebars.hub.ts"],
  "exclude": ["build", ".docusaurus", "node_modules"]
}
